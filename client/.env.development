// This file handles API URLs for both development and production

// Use environment variable in production, fallback to localhost in development
export const API_URL = process.env.REACT_APP_API_URL || 'http://localhost:5000';

// WebSocket URL (use same URL as API)
export const SOCKET_URL = process.env.REACT_APP_API_URL || 'http://localhost:5000';

// Export a helper for API endpoints
export const getApiUrl = (endpoint) => {
  return `${API_URL}${endpoint}`;
};